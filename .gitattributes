# Normaliza line endings: LF no repositório, CRLF no Windows
* text=auto
*.php text eol=lf
*.html text eol=lf
*.js text eol=lf
*.css text eol=lf
*.sql text eol=lf
*.sh text eol=lf
*.md text eol=lf
*.yml text eol=lf
*.json text eol=lf
*.svg text eol=lf

# Binários — sem conversão
*.jpg binary
*.jpeg binary
*.png binary
*.webp binary
*.ico binary
